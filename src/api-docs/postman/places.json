{
  "info": {
    "name": "BC Maps System - Luca",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "placeId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Register Luca",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('token', pm.response.json().token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/register",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"luca\",\n  \"email\": \"luca@isima.fr\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "2. Login Luca",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('token', pm.response.json().token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/login",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"luca@isima.fr\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "3. Create Place - ISIMA",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('placeId', pm.response.json().id);",
              "pm.test('Has tags', () => pm.expect(pm.response.json().tags).to.not.be.empty);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/places",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"ISIMA\",\n  \"description\": \"École d'ingénieurs en informatique à Clermont-Ferrand\",\n  \"latitude\": 45.7596,\n  \"longitude\": 3.1098,\n  \"tags\": [\"École\", \"Clermont\", \"Informatique\"]\n}"
        }
      }
    },
    {
      "name": "4. Create Place - Volcán Lemptégy",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/places",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Volcán de Lemptégy\",\n  \"description\": \"Volcan ouvert au public près de Clermont-Ferrand\",\n  \"latitude\": 45.7676,\n  \"longitude\": 2.9441,\n  \"tags\": [\"Tourisme\", \"Clermont\", \"Nature\"]\n}"
        }
      }
    },
    {
      "name": "5. Create Place - Brasserie Saint-Pierre",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/places",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Brasserie Saint-Pierre\",\n  \"description\": \"Brasserie typique au centre de Clermont-Ferrand\",\n  \"latitude\": 45.7772,\n  \"longitude\": 3.0870,\n  \"tags\": [\"Restaurant\", \"Clermont\", \"Brasserie\"]\n}"
        }
      }
    },
    {
      "name": "6. Get Place By Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has tags', () => pm.expect(pm.response.json().tags).to.not.be.empty);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/places/{{placeId}}",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "7. Get All Places",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has content', () => pm.expect(pm.response.json().content).to.be.an('array'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/places?page=0&size=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" }
          ]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "8. Search by query - ISIMA",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/places/search?query=ISIMA&page=0&size=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places", "search"],
          "query": [
            { "key": "query", "value": "ISIMA" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" }
          ]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "9. Search by tag - Clermont",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/places/search?tag=Clermont&page=0&size=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places", "search"],
          "query": [
            { "key": "tag", "value": "Clermont" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" }
          ]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "10. Update Place - Luca",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Title updated', () => pm.expect(pm.response.json().title).to.equal('ISIMA - Luca'));"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/api/places/{{placeId}}",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"ISIMA - Luca\",\n  \"description\": \"École recommandée par Luca\",\n  \"latitude\": 45.7596,\n  \"longitude\": 3.1098,\n  \"tags\": [\"École\", \"Clermont\", \"Informatique\", \"Favori\"]\n}"
        }
      }
    },
    {
      "name": "11. Update Position - Luca à ISIMA",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Is current position', () => pm.expect(pm.response.json().currentPosition).to.be.true);"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "url": {
          "raw": "{{baseUrl}}/api/places/position?lat=45.7596&lng=3.1098",
          "host": ["{{baseUrl}}"],
          "path": ["api", "places", "position"],
          "query": [
            { "key": "lat", "value": "45.7596" },
            { "key": "lng", "value": "3.1098" }
          ]
        },
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "12. Get Current Position - Luca",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Is current position', () => pm.expect(pm.response.json().currentPosition).to.be.true);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/places/position",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "13. Delete Current Position - Luca",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/places/position",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    },
    {
      "name": "14. Delete Place - Luca",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/places/{{placeId}}",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      }
    }
  ]
}